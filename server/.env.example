DATABASE_URL=mongodb://localhost:27017/plainb
PORT=5001
NODE_ENV=development

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRATION_TIME=60m
JWT_REFRESH_SECRET=replace-with-a-different-strong-secret
JWT_REFRESH_EXPIRATION=7d

FRONTEND_URL=http://localhost:5173

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-sender@gmail.com
EMAIL_PASSWORD=your-google-app-password
EMAIL_SECURITY=false

# This account is created or promoted to ADMIN during server startup.
ADMIN_EMAIL=your-admin@gmail.com

CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

REQUEST_LIMIT_TIME=1m
REQUEST_LIMIT_NUMBER=100
WEB_CACHE=false
URL_ENCODED=true
MAX_JSON_SIZE=10mb
