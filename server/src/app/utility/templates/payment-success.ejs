<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Payment received</title>
  </head>
  <body style="margin:0;background:#f3f5f8;font-family:Arial,Helvetica,sans-serif;color:#172033">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding:32px 12px">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:600px;background:#fff;border-radius:12px;overflow:hidden;border:1px solid #e5e9f0">
            <tr>
              <td style="background:#172033;padding:24px 32px;color:#fff;font-size:28px;font-weight:800">
                Plain<span style="color:#22b573">B</span>
              </td>
            </tr>
            <tr>
              <td style="padding:34px 32px">
                <div style="width:52px;height:52px;line-height:52px;border-radius:50%;background:#e8f7f0;color:#168557;text-align:center;font-size:28px;font-weight:700">✓</div>
                <h1 style="margin:18px 0 8px;font-size:25px">Payment received</h1>
                <p style="margin:0 0 24px;color:#667085;line-height:1.6">
                  Hi <%= name || 'there' %>, your payment was successful and your order is now being processed.
                </p>
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f8fafc;border-radius:10px;padding:10px 18px">
                  <tr><td style="padding:10px 0;color:#667085">Invoice</td><td align="right" style="font-weight:700"><%= invoiceId %></td></tr>
                  <tr><td style="padding:10px 0;color:#667085">Transaction</td><td align="right" style="font-weight:700"><%= transactionId %></td></tr>
                  <tr><td style="padding:10px 0;color:#667085">Payment date</td><td align="right" style="font-weight:700"><%= paymentDate %></td></tr>
                  <tr><td style="padding:12px 0;border-top:1px solid #e5e9f0;font-size:16px;font-weight:700">Amount paid</td><td align="right" style="padding:12px 0;border-top:1px solid #e5e9f0;font-size:18px;font-weight:800;color:#168557"><%= amount %> <%= currency %></td></tr>
                </table>
                <div style="text-align:center;margin-top:28px">
                  <a href="<%= orderUrl %>" style="display:inline-block;background:#168557;color:#fff;text-decoration:none;padding:13px 22px;border-radius:7px;font-weight:700">View your orders</a>
                </div>
              </td>
            </tr>
            <tr>
              <td style="padding:18px 32px;background:#f8fafc;color:#98a2b3;font-size:12px;text-align:center">
                Thank you for shopping with PlainB.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
