<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PlainB login code</title>
  </head>
  <body style="margin:0;background:#f3f5f8;font-family:Arial,Helvetica,sans-serif;color:#172033">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="padding:32px 12px">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:560px;background:#fff;border-radius:12px;overflow:hidden;border:1px solid #e5e9f0">
            <tr>
              <td style="background:#172033;padding:24px 32px;color:#fff;font-size:28px;font-weight:800">
                Plain<span style="color:#22b573">B</span>
              </td>
            </tr>
            <tr>
              <td style="padding:34px 32px">
                <h1 style="margin:0 0 12px;font-size:24px">Your login code</h1>
                <p style="margin:0 0 24px;color:#667085;line-height:1.6">
                  Use this one-time password to securely sign in to your PlainB account.
                </p>
                <div style="background:#eef9f4;border:1px solid #c9eedc;border-radius:10px;padding:20px;text-align:center;font-size:34px;font-weight:800;letter-spacing:8px;color:#168557">
                  <%= otp %>
                </div>
                <p style="margin:24px 0 0;color:#667085;line-height:1.6">
                  If you did not request this code, you can safely ignore this email. Never share your OTP with anyone.
                </p>
              </td>
            </tr>
            <tr>
              <td style="padding:18px 32px;background:#f8fafc;color:#98a2b3;font-size:12px;text-align:center">
                This is an automated security message from PlainB.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
